# Copy to .env and adjust. `docker compose` reads it automatically.

# Your MoQ relay. The bridge publishes each incoming stream here as "<key>.hang".
# Use host.docker.internal to reach a relay running on the same host.
MOQ_URL=http://host.docker.internal:4443/anon

# RTMP authentication: your backend endpoint that validates the stream key.
# MediaMTX POSTs the publish attempt here; return 2xx to allow, 401/403 to deny.
RTMP_AUTH_URL=https://your-backend.example.com/mediamtx/auth
# For local testing WITHOUT a backend, set this to "internal" to allow any key:
RTMP_AUTH_METHOD=http

# MinIO (only used with: docker compose --profile minio up)
MINIO_URL=http://host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=recordings
